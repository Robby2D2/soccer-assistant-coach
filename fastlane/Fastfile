desc "Bump pubspec.yaml version, commit, tag, and push to trigger CI. Usage: bump version:1.0.5 build:5"
lane :bump do |options|
  version = options[:version]
  build   = options[:build]
  UI.user_error!("Pass version: e.g. version:1.0.5") unless version
  UI.user_error!("Pass build: e.g. build:5") unless build

  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  pubspec = File.read(pubspec_path)
  updated = pubspec.sub(/^version: .+$/, "version: #{version}+#{build}")
  File.write(pubspec_path, updated)

  git_commit(path: pubspec_path, message: "chore: bump version to #{version}+#{build}")
  add_git_tag(tag: "v#{version}")
  push_to_git_remote(tags: true)

  UI.success("Tagged v#{version} — CI release workflows triggered.")
end

desc "Create a new release: bump version, tag, push. CI builds and ships to Play Store beta + TestFlight. Usage: create_release version:1.0.9 build:10"
lane :create_release do |options|
  bump(options)
  UI.success("v#{options[:version]} created.")
  UI.message("Android: AAB will land on Play Store beta track once release.yml completes.")
  UI.message("iOS: IPA will land on TestFlight once release-ios.yml completes.")
  UI.message("When ready, promote both with: bundle exec fastlane promote_release version:#{options[:version]}")
  UI.important("⚠️  After fastlane bump pushes locally, the push may fail silently from WSL. Verify with:")
  UI.important("    git ls-remote --tags origin v#{options[:version]}")
  UI.important("If empty, push from PowerShell: git push origin main && git push origin v#{options[:version]}")
end

desc "Promote v.X.Y.Z to production: submit iOS TestFlight build to Apple review, THEN promote Play Store beta to production. Usage: promote_release version:1.0.9"
lane :promote_release do |options|
  version = options[:version]
  UI.user_error!("Pass version: e.g. version:1.0.9") unless version

  # ─── iOS FIRST: submit for App Store review ────────────────────────────────
  # iOS submission is much more likely to fail (missing screenshots, App Privacy
  # not published, metadata issues). If it fails AFTER we promote Android, you'd
  # have Android live on production but iOS still on TestFlight — confusing and
  # hard to roll back. Submit iOS first; only promote Android if iOS succeeded.
  UI.header("iOS — submitting TestFlight build for App Store review")
  ios_key = app_store_connect_api_key(
    key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content:           ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: true,
  )
  upload_to_app_store(
    api_key:                           ios_key,
    app_version:                       version,
    skip_binary_upload:                true,
    screenshots_path:                  "fastlane/screenshots",
    metadata_path:                     "fastlane/metadata",
    submit_for_review:                 true,
    automatic_release:                 true,
    force:                             true,
    reject_if_possible:                true,
    precheck_include_in_app_purchases: false,
    submission_information: {
      export_compliance_uses_encryption: false,
      add_id_info_uses_idfa:             false,
    },
  )
  UI.success("iOS v#{version} submitted for App Store review — will auto-release when approved.")

  # ─── Android: promote beta → production (only if iOS submission succeeded) ─
  UI.header("Android — promoting beta to production")
  upload_to_play_store(
    track:                   "beta",
    track_promote_to:        "production",
    skip_upload_apk:         true,
    skip_upload_aab:         true,
    skip_upload_metadata:    true,
    skip_upload_changelogs:  true,
    skip_upload_images:      true,
    skip_upload_screenshots: true,
  )
  UI.success("Android v#{version} live on Play Store production track.")

  UI.success("✅ v#{version} promotion complete. iOS will auto-release on the App Store once Apple approves (1-2 days). Android is already live on Play Store production.")
end

desc "Promote ONLY Android beta to production (useful for partial recovery if a previous promote_release succeeded iOS but failed Android, or to roll Android forward independently). Usage: promote_release_android"
lane :promote_release_android do
  upload_to_play_store(
    track:                   "beta",
    track_promote_to:        "production",
    skip_upload_apk:         true,
    skip_upload_aab:         true,
    skip_upload_metadata:    true,
    skip_upload_changelogs:  true,
    skip_upload_images:      true,
    skip_upload_screenshots: true,
  )
  UI.success("Android promoted from beta → production track.")
end

desc "Submit ONLY iOS TestFlight build for App Store review (useful for retrying iOS-only after fixing metadata/screenshot issues). Usage: promote_release_ios version:1.0.9 (version defaults to pubspec.yaml if omitted)"
lane :promote_release_ios do |options|
  version = options[:version]
  if version.nil? || version.to_s.strip.empty?
    pubspec = File.read(File.expand_path("../pubspec.yaml", __dir__))
    version = pubspec.match(/^version:\s+(\S+)\+/)[1]
  end
  ios_key = app_store_connect_api_key(
    key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content:           ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: true,
  )
  upload_to_app_store(
    api_key:                           ios_key,
    app_version:                       version,
    skip_binary_upload:                true,
    screenshots_path:                  "fastlane/screenshots",
    metadata_path:                     "fastlane/metadata",
    submit_for_review:                 true,
    automatic_release:                 true,
    force:                             true,
    reject_if_possible:                true,
    precheck_include_in_app_purchases: false,
    submission_information: {
      export_compliance_uses_encryption: false,
      add_id_info_uses_idfa:             false,
    },
  )
  UI.success("iOS v#{version} submitted for App Store review — will auto-release when approved.")
end

default_platform(:android)

platform :android do
  desc "Build a signed release AAB. Run from a Windows terminal (PowerShell/Git Bash), NOT from WSL — the Flutter SDK shell scripts have Windows line endings that break under WSL."
  lane :build do
    sh("cd .. && flutter build appbundle --release")
  end

  desc "Upload AAB to Play Store. Run from WSL. Pass track:\"internal\"|\"alpha\"|\"beta\"|\"production\" (default: internal)"
  lane :deploy do |options|
    upload_to_play_store(
      track: options[:track] || "internal",
      release_status: "draft",
      aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build a signed AAB and upload to Play Store (default: internal track). Used by release.yml CI on tag push; runs end-to-end on the ubuntu-latest runner where Flutter SDK shell scripts have UNIX line endings."
  lane :release do |options|
    build
    deploy(options)
  end

  desc "Promote an existing release from one track to another. Run from WSL. Usage: promote from:internal to:beta"
  lane :promote do |options|
    from_track = options[:from] || "internal"
    to_track   = options[:to]
    UI.user_error!("Pass to: e.g. to:beta") unless to_track
    upload_to_play_store(
      track:              from_track,
      track_promote_to:   to_track,
      skip_upload_apk:    true,
      skip_upload_aab:    true,
      skip_upload_metadata:    true,
      skip_upload_changelogs:  true,
      skip_upload_images:      true,
      skip_upload_screenshots: true,
    )
  end
end

platform :ios do
  private_lane :api_key do
    app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      is_key_content_base64: true,
    )
  end

  desc "One-time Match initialization — generates dist cert + App Store provisioning profile."
  lane :init_match do
    key = api_key
    match(type: "appstore", readonly: false, api_key: key)
  end

  desc "Sync certs and configure signing. Called by CI before flutter build ipa."
  lane :setup_signing do
    create_keychain(
      name: "build.keychain",
      password: "buildpassword",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )
    key = api_key
    match(
      type: "appstore",
      readonly: true,
      api_key: key,
      keychain_name: "build.keychain",
      keychain_password: "buildpassword",
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: "DPS86D59PK",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.useunix.soccerassistantcoach",
      bundle_identifier: "com.useunix.soccerassistantcoach",
    )
  end

  desc "Upload an existing IPA to TestFlight. Set IPA_PATH env var or let it fall back to glob."
  lane :release do
    ipa_path = ENV["IPA_PATH"].to_s.strip
    ipa_path = Dir.glob("build/ios/ipa/*.ipa").first if ipa_path.empty?
    UI.user_error!("No IPA found — set IPA_PATH or build first") unless ipa_path
    UI.message("Uploading #{ipa_path}")
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               ipa_path,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Sync certs and configure signing (local use). Run from macOS."
  lane :build do
    key = api_key
    match(type: "appstore", readonly: true, api_key: key)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: "DPS86D59PK",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.useunix.soccerassistantcoach",
      bundle_identifier: "com.useunix.soccerassistantcoach",
    )
  end

  desc "Upload an existing IPA at build/ios/ipa/*.ipa to TestFlight."
  lane :deploy do
    ipa_path = Dir.glob("build/ios/ipa/*.ipa").first
    UI.user_error!("No IPA found in build/ios/ipa/") unless ipa_path
    UI.message("Uploading #{ipa_path}")
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               ipa_path,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Upload metadata and screenshots to App Store Connect without submitting for review. Run from WSL."
  lane :metadata do
    upload_to_app_store(
      api_key:            api_key,
      skip_binary_upload: true,
      skip_screenshots:   false,
      screenshots_path:   "fastlane/screenshots",
      metadata_path:      "fastlane/metadata",
      submit_for_review:              false,
      force:                          true,
      precheck_include_in_app_purchases: false,
      app_review_information: {
        first_name:   "Rob",
        last_name:    "Danek",
        phone_number: "+1 612-326-3936",
        email_address: "developer@useunix.com",
        notes:        "Local-first app. No login required. All data is stored on device. Test any feature freely.",
      },
    )
  end

  desc "Upload metadata, screenshots, and submit the latest TestFlight build for App Store review. Run from WSL."
  lane :submit do
    upload_to_app_store(
      api_key:            api_key,
      skip_binary_upload: true,
      screenshots_path:   "fastlane/screenshots",
      metadata_path:      "fastlane/metadata",
      submit_for_review:                 true,
      automatic_release:                 true,
      force:                             true,
      reject_if_possible:                true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa:             false,
      },
    )
  end
end
