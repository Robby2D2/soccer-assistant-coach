# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local SQLite databases (use AppDb.test() in tests; production DB lives under app data dir)
soccer_manager.db
*.db-journal

# Personal/scratch dev notes (kept locally, not tracked)
notes.txt
learnings.txt
patch.sh
flutter_01.png

# Patrol generated test bundle (regenerated automatically on each `patrol test` run)
patrol_test/test_bundle.dart

# Android signing keystore (NEVER commit; generated via keytool)
android/key.properties
android/app/*.keystore
android/app/*.jks

# Google Play API service account key (NEVER commit)
fastlane/google-play-key.json

# Bundler local gem cache and config
vendor/bundle/
.bundle/
